---
import type { InferGetStaticPropsType } from 'astro';
import data from '../../content/yapping-data.json'with { type: 'json'};

export function getStaticPaths() {
	return Object.entries(data).map(([key, item]) => ({ params: { keyword: key }, props: item }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { title, links, text, prompt } = Astro.props;

function randomHex() {
	return Math.trunc(Math.random() * 1000000).toString(16);
}
