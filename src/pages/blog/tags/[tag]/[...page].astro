---
import type { GetStaticPaths, InferGetStaticPropsType, PaginateFunction } from 'astro';
import BlogPosts from '../../../../components/BlogPosts/BlogPosts.astro';
import { listPostsByTag, MAX_POSTS_PER_PAGE } from '../../../../utils/post';

export const getStaticPaths = (async ({ paginate }: { paginate: PaginateFunction }) => {
	const postsList = await listPostsByTag();

	return Object.entries(postsList).flatMap(([tagKey, taggedPostsList]) =>
		paginate(taggedPostsList, {
			params: { tag: tagKey },
			pageSize: MAX_POSTS_PER_PAGE
		})
	);
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const {
	data: posts,
	currentPage,
	lastPage,
	start,
	end,
	total,
	size
} = Astro.props.page;
const { tag } = Astro.params;

const createdAt = posts.reduce((curDate, { data: { createdAt: createdDate } }) => {
	if (createdDate.getDate() > curDate.getDate()) {
		return createdDate;
	}

	return curDate;
	// oxlint-disable-next-line typescript/no-non-null-assertion
}, posts[0]!.data.createdAt);

const updatedAt = posts.reduce<Date | undefined>((curDate, { data: { updatedAt: updatedDate } }) => {
	if (!updatedDate) {
		return curDate;
	}

	if (curDate && updatedDate.getDate() > curDate.getDate()) {
		return updatedDate;
	}

	return curDate;
}, undefined);
---
<BlogPosts
	title={`Posts tagged with: "${tag}"`}
	baseUrl={`/blog/tags/${tag}/`}
	{posts}
	{currentPage}
	{lastPage}
	{start}
	{end}
	{total}
	{size}
	{createdAt}
	{updatedAt}
/>
