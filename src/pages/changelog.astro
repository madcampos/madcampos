---
import CssNakedDay from '../components/CssNakedDay/CssNakedDay.astro';
import DecoratedLine from '../components/DecoratedLine/DecoratedLine.astro';
import HtmlHead from '../components/HtmlHead/HtmlHead.astro';
import Logo from '../components/Logo/Logo.astro';
import OldStyleButtons from '../components/OldStyleButtons/OldStyleButtons.astro';
import SiteNav from '../components/SiteNav/SiteNav.astro';
import SvgDefs from '../components/SvgDefs/SvgDefs.astro';
import Webrings from '../components/Webrings/Webrings.astro';
import { listAllChangelogs } from '../utils/changelog.ts';
import { slugify } from '../utils/slug';

const formatter = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeStyle: 'short', timeZone: 'UTC' });
const changelogs = await listAllChangelogs();
const renderedChangelogs = await Promise.all(changelogs.map(async (changelog) => {
	const { Content } = await changelog.render();

	return {
		Content,
		id: changelog.id,
		title: changelog.title,
		date: changelog.data.date,
		draft: changelog.data.draft
	};
}));
---
<!doctype html>
<html lang="en-US" itemscope itemtype="https://schema.org/WebPage">
	<HtmlHead
		title="Changelog | Marco Campos"
		description="List of changes in diferent versions of the website."
		createdAt={new Date('2024-11-22T23:16:26-0500')}
		updatedAt={new Date('2026-07-10T21:15:36-0400')}
	/>
	<body>
		<a href="/yapping" rel="nofollow" hidden>Don't follow this link</a>

		<skip-to-content>
			<a href="#main">Skip to main content</a>
		</skip-to-content>

		<SiteNav />
		<CssNakedDay />

		<header>
			<Logo
				subtitle="Changelog"
				shortSubtitle="Log"
				title="Changelog page"
			/>
			<h1 data-pagefind-meta="title">Changelog</h1>
		</header>

		<main data-pagefind-body id="main">
			{renderedChangelogs.map(({ id, date, title, draft, Content }) => (
				<details id={slugify(id)}>
					<summary>
						<header>
							<h2>
								{draft && <draft-tag>Draft</draft-tag>}
								<Fragment set:html={title} />
							</h2>
							<p>
								<time
									data-relative-time
									datetime={date.toISOString()}
								>{formatter.format(date)}</time>
							</p>
						</header>
					</summary>
					<article>
						<Content />
					</article>
				</details>
			))}
		</main>

		<footer>
			<DecoratedLine />

			<OldStyleButtons />
			<Webrings />
			<hit-counter></hit-counter>
		</footer>
		<SvgDefs />
		<iab-escape></iab-escape>
		<script src="../components/RelativeTime/relative-time.ts"></script>
	</body>
</html>
