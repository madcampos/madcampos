---
import { Image } from 'astro:assets';
import avatar from '../../public/assets/images/me.jpg';
import CssNakedDay from '../components/CssNakedDay/CssNakedDay.astro';
import DecoratedLine from '../components/DecoratedLine/DecoratedLine.astro';
import HtmlHead from '../components/HtmlHead/HtmlHead.astro';
import Logo from '../components/Logo/Logo.astro';
import OldStyleButtons from '../components/OldStyleButtons/OldStyleButtons.astro';
import SiteNav from '../components/SiteNav/SiteNav.astro';
import SvgDefs from '../components/SvgDefs/SvgDefs.astro';
import Webrings from '../components/Webrings/Webrings.astro';
---
<!doctype html>
<html lang="en-US" itemscope itemtype="https://schema.org/WebPage">
	<HtmlHead
		title="@madcampos | Marco Campos"
		description="Social Media activity for @madcampos"
	/>
	<body>
		<a href="/yapping" rel="nofollow" hidden>Don't follow this link</a>

		<skip-to-content>
			<a href="#main">Skip to main content</a>
		</skip-to-content>

		<SiteNav />
		<CssNakedDay />

		<header>
			<Logo
				subtitle="Profile page"
				shortSubtitle="@"
				title="@madcampos"
			/>
			<h1 data-pagefind-meta="title">@madcampos</h1>
		</header>

		<main
			data-pagefind-body
			id="main"
			class="h-card vcard"
			itemprop="mainEntity"
			itemtype="https://schema.org/Person"
			itemscope
		>
			<meta class="p-nickname nickname" itemprop="alternateName" content="madcampos" />
			<meta class="p-name fn n" itemprop="name" content="Marco Campos" />
			<m-avatar>
				<picture
					class="user-avatar"
					itemprop="image"
					itemscope
					itemtype="https://schema.org/ImageObject"
				>
					<Image
						class="u-photo photo"
						itemprop="contentUrl"
						src={avatar}
						alt="A picture of my face with a smile looking at the camera. I&apos;m wearing aviator glasses, a fake fur winter hat and an orange scarf."
						loading="eager"
						widths={[128, 256, 512, 768, 1024]}
						width={512}
						sizes="
							auto,
							(max-width: 25rem) 256px,
							(max-width: 40rem) 388px,
							(max-width: 50rem) 448px,
							512px
						"
					/>
				</picture>
			</m-avatar>

			<details open>
				<summary>
					<h2>Online Activity</h2>
				</summary>

				<p>No published activity.</p>
			</details>
		</main>

		<footer>
			<DecoratedLine />

			<OldStyleButtons />
			<Webrings />
			<hit-counter></hit-counter>
		</footer>
		<SvgDefs />
		<iab-escape></iab-escape>
	</body>
</html>
