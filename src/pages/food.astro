---
import CssNakedDay from '../components/CssNakedDay/CssNakedDay.astro';
import HtmlHead from '../components/HtmlHead/HtmlHead.astro';
import Logo from '../components/Logo/Logo.astro';
import OldStyleButtons from '../components/OldStyleButtons/OldStyleButtons.astro';
import SiteNav from '../components/SiteNav/SiteNav.astro';
import SvgDefs from '../components/SvgDefs/SvgDefs.astro';
import Webrings from '../components/Webrings/Webrings.astro';
import '../assets/pages/food/food.css';
---
<!DOCTYPE html>
<html lang="en-US" itemscope itemtype="https://schema.org/WebPage">
	<HtmlHead
		title="Food order | Marco Campos"
		description="What food to order at different places."
	/>
	<body>
		<a href="/yapping" rel="nofollow" hidden>Don't follow this link</a>

		<skip-to-content>
			<a href="#main">Skip to main content</a>
		</skip-to-content>

		<SiteNav />
		<CssNakedDay />

		<header>
			<Logo
				subtitle="Food Order"
				shortSubtitle="Food"
				title="Food Order page"
			/>
			<h1>Food Order</h1>
		</header>

		<main id="main">
			<wheel-of-fortune items="Tim Hortons, Subway, A&W, Ice Cream, Pizza"></wheel-of-fortune>

			<details name="food-options" id="tim-hortons">
				<summary>Tim Hortons</summary>

				<strong>Coffee</strong>
				<ul>
					<li>Medium French Vanilla</li>
				</ul>

				<strong>Savory food</strong>
				<ul>
					<li>Herb and garlic pastry</li>
					<li>Red peppers and Swiss cheese pastry</li>
				</ul>

				<strong>Sweets</strong>
				<ul>
					<li>Boston cream doughnut</li>
					<li>Wild blueberry muffin</li>
				</ul>
			</details>

			<details name="food-options" id="subway">
				<summary>Subway</summary>

				<ol>
					<li>Any bread, 6 inches</li>
					<li>Cheddar cheese</li>
					<li>Lettuce, onions, olives, green bell peppers</li>
					<li>Honey mustard sauce</li>
				</ol>
			</details>

			<details name="food-options" id="a-w">
				<summary>A&W</summary>

				<p>Beyond meet combo, with onion rings, and root beer.</p>
			</details>

			<details name="food-options" id="ice-cream">
				<summary>Ice Cream flavors</summary>

				<ol>
					<li>Mint chocolate chips</li>
					<li>Cookies and cream</li>
					<li>Salty caramel</li>
					<li>Chocolate</li>
				</ol>
			</details>

			<details name="food-options" id="pizza">
				<summary>Pizza flavors</summary>

				<p>Any vegetarian pizza will do, but preffered toppings are:</p>

				<ul>
					<li>Olives</li>
					<li>Bell peppers</li>
					<li>Mushrooms</li>
					<li>Sun dried tomatoes</li>
					<li>Onions</li>
				</ul>
			</details>
		</main>

		<footer>
			<OldStyleButtons />
			<Webrings />
			<hit-counter></hit-counter>
		</footer>
		<SvgDefs />
		<iab-escape></iab-escape>
		<script src="../components/WheelOfFortune/wheel-of-fortune.ts"></script>
	</body>
</html>
