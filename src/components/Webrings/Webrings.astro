---
import './webrings.css';
import { Icon } from 'astro-icon/components';
---
<m-webrings>
	<details open>
		<summary>
			<Icon name="mingcute:world-2-line" aria-hidden="true" />
			<span>Webrings</span>
		</summary>

		<dl>
			<dt>
				<a rel="external noopener" href="https://a11y-webring.club/">a11y-webring.club</a>
			</dt>
			<dd>
				<ul>
					<li>
						<a referrerpolicy="strict-origin" rel="external noopener" href="https://a11y-webring.club/prev">
							<Icon name="mingcute:arrows-left-line" aria-hidden="true" />
							<span>Previous website</span>
						</a>
					</li>
					<li>
						<a referrerpolicy="strict-origin" rel="external noopener" href="https://a11y-webring.club/random">
							<Icon name="mingcute:shuffle-line" aria-hidden="true" />
							<span>Random website</span>
						</a>
					</li>
					<li>
						<a referrerpolicy="strict-origin" rel="external noopener" href="https://a11y-webring.club/next">
							<span>Next website</span>
							<Icon name="mingcute:arrows-right-line" aria-hidden="true" />
						</a>
					</li>
				</ul>
			</dd>

			<dt>
				<a rel="external noopener" href="https://webring.torontojs.com">Toronto JS Webring</a>
			</dt>
			<dd>
				<ul>
					<li>
						<a referrerpolicy="strict-origin" rel="external noopener" href="https://webring.torontojs.com/prev">
							<Icon name="mingcute:arrows-left-line" aria-hidden="true" />
							<span>Previous website</span>
						</a>
					</li>
					<li>
						<a referrerpolicy="strict-origin" rel="external noopener" href="https://webring.torontojs.com/random">
							<Icon name="mingcute:shuffle-line" aria-hidden="true" />
							<span>Random website</span>
						</a>
					</li>
					<li>
						<a referrerpolicy="strict-origin" rel="external noopener" href="https://webring.torontojs.com/next">
							<span>Next website</span>
							<Icon name="mingcute:arrows-right-line" aria-hidden="true" />
						</a>
					</li>
				</ul>
			</dd>
		</dl>
	</details>
</m-webrings>
