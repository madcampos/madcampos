---
import './color-swatch.css';

interface Props {
	name?: string;
	colorHex: string;
	colorOklch: string;
	colorHsl: string;
}

const { colorHex, colorHsl, colorOklch, name } = Astro.props;
---
<color-swatch>
	<figure>
		<article style={`--swatch-color: ${colorHex};`}></article>
		<figcaption>
			<data value={colorHex}>{name ?? colorHex}</data>
			<br />
			<code>{colorHex}</code>
			<br />
			<code>{colorOklch}</code>
			<br />
			<code>{colorHsl}</code>
		</figcaption>
	</figure>
</color-swatch>
