{
	"name": "madcampos-site",
	"private": true,
	"version": "5.0.0",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=24.13.0",
		"pnpm": ">=10.26.2"
	},
	"scripts": {
		"bootstrap:astro": "astro sync",
		"bootstrap:types": "wrangler types server/env.d.ts",
		"bootstrap:env-vars": "varlock typegen",
		"bootstrap:certs": "mkdir certs && mkcert -key-file='./certs/server.key' -cert-file='./certs/server.crt' 'localhost'",
		"bootstrap:puppeteer": "puppeteer browsers install chrome",
		"bootstrap": "pnpm run bootstrap:types && pnpm run bootstrap:env-vars && pnpm run bootstrap:astro",
		"prestart:api": "pnpm run bootstrap:types",
		"start:api": "wrangler dev --env=local --https-cert-path certs/server.crt --https-key-path certs/server.key",
		"prestart": "pnpm run bootstrap:astro",
		"start": "astro dev --site=https://localhost:3000/",
		"prebuild": "pnpm run bootstrap",
		"build": "astro build",
		"postbuild": "pagefind --site dist",
		"build:resume": "node --experimental-strip-types ./build/save-resume-pdf.ts",
		"prepreview": "pnpm run build",
		"preview": "astro preview --site=https://localhost:3000/",
		"predeploy": "pnpm run build && pnpm run db:migrations:remote",
		"deploy": "wrangler deploy --minify --env=\"\"",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit",
		"lint:js": "oxlint --fix",
		"lint:md": "astro check",
		"lint": "pnpm run typecheck && pnpm run lint:js && pnpm run lint:md",
		"db:migrations:local": "wrangler d1 migrations apply madcampos-site-db",
		"db:migrations:remote": "wrangler d1 migrations apply madcampos-site-db --remote",
		"version": "pnpm version --sign-git-tag --message \"chore: update package version\"",
		"postversion": "pnpm run changelog --output \"docs/changelog\" --push --create-release"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/markdown-remark": "7.2.1",
		"@astrojs/sitemap": "3.7.3",
		"@astropub/md": "^1.0.0",
		"@iconify-json/fa6-brands": "1.2.6",
		"@iconify-json/mingcute": "1.2.7",
		"@mad-c/config": "^2.2.0",
		"@shikijs/transformers": "4.3.1",
		"@shikijs/twoslash": "4.3.1",
		"@types/hast": "3.0.4",
		"@types/node": "26.1.0",
		"@zip.js/zip.js": "2.8.26",
		"astro": "7.0.6",
		"astro-icon": "1.1.5",
		"oxlint": "^1.72.0",
		"oxlint-tsgolint": "^0.24.0",
		"pagefind": "^1.5.2",
		"puppeteer": "25.3.0",
		"rehype-autolink-headings": "7.1.0",
		"rehype-external-links": "3.0.0",
		"remark-breaks": "4.0.0",
		"remark-flexible-markers": "1.3.5",
		"remark-ins": "1.2.5",
		"sharp": "^0.35.3",
		"typescript": "6.0.3",
		"unist-util-visit": "5.1.0",
		"wrangler": "4.110.0"
	},
	"overrides": {
		"es-set-tostringtag": "npm:@nolyfill/es-set-tostringtag@^1",
		"safer-buffer": "npm:@nolyfill/safer-buffer@^1",
		"yaml-language-server": {
			"prettier": "2.8.7"
		}
	},
	"dependencies": {
		"gl-matrix": "3.4.4",
		"inapp-spy": "5.0.10",
		"open-props": "1.7.23",
		"varlock": "^1.9.0",
		"web-features": "3.32.0"
	}
}
